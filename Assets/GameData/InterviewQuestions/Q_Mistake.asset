  m_Name: Q_Mistake
  m_EditorClassIdentifier: Assembly-CSharp::Simulator_Game.InterviewQuestion
  questionText: Describe a significant mistake you made and what you learned from
    it.
  answerPool:
  - answerText: I missed a deadline, owned it, communicated early, and built better
      tracking afterwards.
    scoreModifier: 0.3
  - answerText: I haven't really made any significant mistakes.
    scoreModifier: -0.3
  - answerText: I shipped a bug to production. I learned to test edge cases more
      carefully.
    scoreModifier: 0.2
  - answerText: It was actually my coworker's fault, but I got blamed.
    scoreModifier: -0.3
  - answerText: I underestimated a project's scope. Now I always pad estimates and
      surface risks early.
    scoreModifier: 0.25
