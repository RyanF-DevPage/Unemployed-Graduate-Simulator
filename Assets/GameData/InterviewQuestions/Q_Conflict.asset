  m_Script: {fileID: 11500000, guid: d627df4260b47b94780c949f0ee7ee7d, type: 3}
  m_Name: Q_Conflict
  m_EditorClassIdentifier: Assembly-CSharp::Simulator_Game.InterviewQuestion
  questionText: Tell me about a time you faced a conflict at work. How did you resolve
    it?
  answerPool:
  - answerText: I sat down with the other person, listened to their perspective,
      and we found a compromise.
    scoreModifier: 0.3
  - answerText: I escalated the issue to my manager immediately.
    scoreModifier: -0.1
  - answerText: I avoided them until the project ended.
    scoreModifier: -0.3
  - answerText: I worked around them and didn't bring it up.
    scoreModifier: -0.2
  - answerText: I called a team meeting to surface the disagreement and align on
      goals.
    scoreModifier: 0.25
